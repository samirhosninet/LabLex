# LabLex Environment Variables Configuration example
# Copy this file to .env for local development

# Database configuration
DATABASE_URL=postgresql://lablex_admin:lablex_password@localhost:5432/lablex_db

# Cache/Queue configuration
REDIS_URL=redis://localhost:6379/0

# Object Storage configuration (MinIO / S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=lablex-artifacts

# Authentication Configuration
JWT_SECRET=supersecretjwtkeyforlocaldevelopment12345!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# KMS Cryptography KEK (For secret_refs encryption)
# Must be exactly 32 bytes for AES-256-GCM in local development mode
ENCRYPTION_KEY=local-dev-kek-key-32-chars-long123
